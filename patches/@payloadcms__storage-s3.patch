+        if (uploadedFiles.has(cacheKey)) {
+            console.log(`[S3ClientUploadHandler] Skipping S3 upload for "${file.name}" as it was already uploaded in this session.`);
+            return {
+                prefix
+            };
+        }
+
         const endpointRoute = formatAdminURL({
             apiRoute,
             path: serverHandlerPath,
